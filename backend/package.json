{
  "name": "sistema-barber-backend",
  "version": "1.0.0",
  "description": "Backend Node.js + Express para sistema local de barbearia com SQLite e JWT",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "node scripts/package-windows.js",
    "build:exe": "pkg server.js --out-path dist --targets node18-win-x64",
    "db:init": "node src/database/init.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": "src/**/*.js",
    "assets": [
      "src/database/schema.sql",
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node"
    ]
  }
}
